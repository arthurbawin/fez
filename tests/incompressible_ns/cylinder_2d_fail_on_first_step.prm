
#
# Same as cylinder_2d.prm, but set a large first time step to have
# the nonlinear solver fail and try again with a smaller time step.
#
# The time step for which the nonlinear solvers diverges with a BDF1
# here is ginormous, dt = 200, as it converges even for dt = 100.
#
subsection Dimension
  set dimension = 2
end

subsection Timer
  set enable timer = false
end

subsection Output
  set write vtu results = false
end

subsection Mesh
  set mesh file = ../../cylinder_2d.msh
end

subsection Time integration
  set dt        = 200.
  set t_initial = 0
  set t_end     = 200.
  set scheme    = BDF1

  subsection Adaptation
    set verbosity = verbose
    set enable    = true

    #
    # Do not bound the time step above or below, to not alter the 
    # convergence rates
    #
    set max timestep = 100.
    set min timestep = 1e-6
    set max timestep increase = 100.
    set max timestep reduction = 1e-6

    # Initial target error, divided by 2 at each convergence study step
    set target error on temperature = 1e-2
  end
end

subsection Nonlinear solver
  set tolerance            = 1e-10
  set divergence_tolerance = 1e+4
  set max_iterations       = 50
  set enable_line_search   = false
  set analytic_jacobian    = true
end

subsection Linear solver
  subsection main physics
    set verbosity      = quiet
    set method         = direct_mumps
    set reuse          = true
  end
end

subsection FiniteElements
  set Velocity degree            = 2
  set Pressure degree            = 1
end

subsection Physical properties
  set number of fluids = 1
  subsection Fluid 0
    set density             = 1
    set kinematic viscosity = 0.005
  end
end

subsection Initial conditions
  subsection velocity
    set Function expression = 1; 0
  end
end

subsection Fluid boundary conditions
  set number = 4
  subsection boundary 0
    set id   = 1
    set name = Outlet
    set type = outflow
  end
  subsection boundary 1
    set id   = 2
    set name = Inlet
    set type = input_function
    subsection u
      set Function expression = 1
    end
    subsection v
      set Function expression = 0
    end
  end
  subsection boundary 2
    set id   = 3
    set name = NoFlux
    set type = slip
  end
  subsection boundary 3
    set id   = 4
    set name = InnerBoundary
    set type = no_slip
  end
end

subsection Postprocessing
  subsection forces computation
    set verbosity          = verbose
    set enable             = true
    set boundary id        = 4
    set write results      = false
    set computation method = stress vector
    set precision          = 12
  end
end