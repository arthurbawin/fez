
subsection Dimension
  set dimension = 3
end

subsection Timer
  set enable timer = false
end

subsection Output
  set write vtu results = false
  set output directory  = ../tmp/results/
  set output prefix     = solution
end

subsection Mesh

  set dealii preset mesh     = rectangle
  set dealii mesh parameters = 10, 5, 5 : -2, -1., -1. : 2., 1., 1. : true
  set refinement level       = 1

  subsection Adaptation
    set verbosity                = verbose
    set enable                   = true
    set adaptation directory     = adaptation/
    set adapted meshes extension = adapted
    set strategy                 = local refinement

    subsection Local refinement
      set adapt frequency               = 1
      set refinement strategy           = fixed number
      set fraction to refine            = 0.3
      set fraction to coarsen           = 0.5
      set min grid level                = 0
      set max grid level                = 3
      set max number of cells           = 2000
      set number of prerefinement steps = 2
    end
  end
end

subsection Time integration
  set verbosity = verbose
  set dt        = 0.05
  set t_initial = 0
  set t_end     = 0.15
  set scheme    = BDF1
end

subsection Nonlinear solver
  set tolerance            = 1e-6
  set divergence_tolerance = 1e+4
  set max_iterations       = 20
  set enable_line_search   = false
  set analytic_jacobian    = true
end

subsection Linear solver
  subsection main physics
    set verbosity      = quiet
    set method         = cg
    set preconditioner = block_jacobi
    set tolerance      = 1e-10
    set max iterations = 1000
  end
end

subsection FiniteElements
  set use quads          = true
  set Temperature degree = 1
end

subsection Initial conditions
  set to mms = true
end

subsection Heat boundary conditions
  set number = 6
  subsection boundary 0
    set id   = 0
    set name = x_min
    set type = dirichlet_mms
  end
  subsection boundary 1
    set id   = 1
    set name = x_max
    set type = dirichlet_mms
  end
  subsection boundary 2
    set id   = 2
    set name = y_min
    set type = dirichlet_mms
  end
  subsection boundary 3
    set id   = 3
    set name = y_max
    set type = dirichlet_mms
  end
  subsection boundary 4
    set id   = 4
    set name = y_min
    set type = dirichlet_mms
  end
  subsection boundary 5
    set id   = 5
    set name = y_max
    set type = dirichlet_mms
  end
end

subsection Exact solution
  subsection exact temperature
    set Function constants = c=0, delta=0.1, x_0 = -0.
    set Function expression = tanh( (2*(x - x_0 - c*t) - sin(5*y) -  sin(pi*z)) / delta)
  end
end

subsection Manufactured solution
  set enable                 = true
  set type                   = space
  set convergence steps      = 1

  subsection Space convergence
    set norms to compute = L2_norm, Linfty_norm, H1_seminorm
  end
end