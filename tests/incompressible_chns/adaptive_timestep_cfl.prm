
subsection Dimension
  set dimension = 2
end

subsection Timer
  set enable timer = false
end

subsection Output
  set write vtu results = false
end

subsection Mesh
  set dealii preset mesh     = rectangle
  set dealii mesh parameters = 60, 1 : 0., 0. : 0.6, 0.05 : true
  set refinement level       = 1
end

subsection Time integration
  set dt               = 0.01
  set t_initial        = 0
  set t_end            = 0.02
  set scheme           = BDF2
  set bdf start method = BDF1
  subsection Adaptation
    set verbosity = verbose
    set enable = true
    set adaptation strategy = cfl
    set max timestep = 0.05
    set min timestep = 1e-6
    set max timestep increase = 2
    set max timestep reduction = 0.1
    set target cfl number = 1
    set reject timestep with large cfl = true
    set cfl ratio to reject = 1
  end
end

subsection Nonlinear solver
  set tolerance            = 1e-10
  set divergence_tolerance = 1e+4
  set max_iterations       = 40
  set enable_line_search   = true
  set analytic_jacobian    = true
end

subsection Linear solver
  subsection main physics
    set verbosity      = quiet
    set method         = direct_mumps
    set reuse          = true
  end
end

subsection FiniteElements
  set use quads = true
  set Velocity degree   = 2
  set Pressure degree   = 1
  set Tracer degree     = 1
  set Potential degree  = 1
  set stabilization = true
end

subsection Physical properties
  set body force = 0, 0
  set number of fluids = 2
  subsection Fluid 0
    set density             = 1
    set kinematic viscosity = 0.1
  end
  subsection Fluid 1
    set density             = 1
    set kinematic viscosity = 0.1
  end
end

subsection Cahn Hilliard
  set mobility model      = constant
  set mobility            = 1e-4
  set surface tension     = 20e-3
  set interface thickness = 1e-2
  set enable tracer limiter = true
end

subsection Initial conditions
  subsection velocity
    set Function expression = 1.8; 0
  end
  subsection cahn hilliard tracer
    set Function constants  = eps=1e-2, ux=1.8, xc=0.25
    set Function expression = tanh(((x-xc) - ux*t)/(sqrt(2.)*eps))
  end
end

subsection Fluid boundary conditions
  set number = 4
  set fix pressure constant = true
  set enforce zero mean pressure = false
  subsection boundary 0
    set id   = 0
    set name = x_min
    set type = input_function
    subsection u
      set Function expression = 1.8
    end
    subsection v
      set Function expression = 0
    end
  end
  subsection boundary 1
    set id   = 1
    set name = x_max
    set type = input_function
    subsection u
      set Function expression = 1.8
    end
    subsection v
      set Function expression = 0
    end
  end
  subsection boundary 2
    set id   = 2
    set name = y_min
    set type = input_function
    subsection u
      set Function expression = 1.8
    end
    subsection v
      set Function expression = 0
    end
  end
  subsection boundary 3
    set id   = 3
    set name = y_max
    set type = input_function
    subsection u
      set Function expression = 1.8
    end
    subsection v
      set Function expression = 0
    end
  end
end

subsection CahnHilliard boundary conditions
  set number = 4
  subsection boundary 0
    set id   = 0
    set name = x_min
    set type = no_flux
  end
  subsection boundary 1
    set id   = 1
    set name = x_max
    set type = no_flux
  end
  subsection boundary 2
    set id   = 2
    set name = y_min
    set type = no_flux
  end
  subsection boundary 3
    set id   = 3
    set name = y_max
    set type = no_flux
  end
end

subsection Debug
  set verbosity                              = verbose
  set apply exact solution                   = false
  set compare jacobian matrix with fd        = false
  set analytical_jacobian_absolute_tolerance = 1e-3
  set analytical_jacobian_relative_tolerance = 1e-3
end
