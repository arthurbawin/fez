
subsection Dimension
  set dimension = 2
end

subsection Timer
  set enable timer = false
end

subsection Output
  set write vtu results = false
end

subsection Mesh
  set dealii preset mesh     = rectangle
  set dealii mesh parameters = 5, 10 : 0., 0. : 1., 2. : true
  set refinement level       = 1
end


subsection Time integration
  set dt               = 0.01
  set t_initial        = 0
  set t_end            = 0.03
  set scheme           = BDF1
end

subsection Nonlinear solver
  set tolerance            = 1e-10
  set divergence_tolerance = 1e+4
  set max_iterations       = 40
  set enable_line_search   = true
  set analytic_jacobian    = true

  set compare jacobian matrix with finite differences = true
  set analytical_jacobian_absolute_tolerance = 1e-4
  set analytical_jacobian_relative_tolerance = 1e-4
end

subsection Linear solver
  subsection main physics
    set verbosity      = quiet
    set method         = direct_mumps
    set reuse          = true
  end
end

subsection FiniteElements
  set Velocity degree   = 2
  set Pressure degree   = 1
  set Tracer degree     = 1
  set Potential degree  = 1
end

subsection Physical properties
  set number of fluids = 2
  subsection Fluid 0
    set density             = 1000
    set kinematic viscosity = 0.01
  end
  subsection Fluid 1
    set density             = 100
    set kinematic viscosity = 0.01
  end
  set number of pseudosolids = 1
  subsection Pseudosolid 0
    subsection lame lambda
      set Function expression = 1
    end
    subsection lame mu
      set Function expression = 1
    end
  end
  set body force = 0, -0.981
end

subsection Cahn Hilliard
  set mobility model        = constant
  set mobility              = 6.1e-6
  set surface tension       = 24.5
  set interface thickness   = 1
  set enable tracer limiter = false
end

subsection Initial conditions
  subsection velocity
    set Function expression = 0; 0
  end
  subsection cahn hilliard tracer
    set Function constants  = eps=1, R0=0.25, xc=0.5, yc=0.5
    set Function expression =tanh((sqrt((x-xc)^2 + (y-yc)^2) - R0)/(sqrt(2.)*eps))
  end
end

subsection Fluid boundary conditions
  set number = 4
  set fix pressure constant = true
  set enforce zero mean pressure = false
  subsection boundary 0
    set id   = 0
    set name = x_min
    set type = slip
  end
  subsection boundary 1
    set id   = 1
    set name = x_max
    set type = slip
  end
  subsection boundary 2
    set id   = 2
    set name = y_min
    set type = no_slip
  end
  subsection boundary 3
    set id   = 3
    set name = y_max
    set type = no_slip
  end
end

subsection Pseudosolid boundary conditions
  set number = 4
  subsection boundary 0
    set id   = 0
    set name = x_min
    set type = input_function
    subsection x
      set Function expression = x
    end
    subsection y
      set Function expression = y + 0.4 * y * (y-2) * sin(2*pi*t)
    end
  end
  subsection boundary 1
    set id   = 1
    set name = x_max
    set type = input_function
    subsection x
      set Function expression = x
    end
    subsection y
      set Function expression = y + 0.4 * y * (y-2) * sin(2*pi*t)
    end
  end
  subsection boundary 2
    set id   = 2
    set name = y_min
    set type = input_function
    subsection x
      set Function expression = x + 0.4 * x * (x-1) * sin(2*pi*t)
    end
    subsection y
      set Function expression = y
    end
  end
  subsection boundary 3
    set id   = 3
    set name = y_max
    set type = input_function
    subsection x
      set Function expression = x + 0.4 * x * (x-1) * sin(2*pi*t)
    end
    subsection y
      set Function expression = y
    end
  end
end

subsection CahnHilliard boundary conditions
  set number = 4
  subsection boundary 0
    set id   = 0
    set name = x_min
    set type = no_flux
  end
  subsection boundary 1
    set id   = 1
    set name = x_max
    set type = no_flux
  end
  subsection boundary 2
    set id   = 2
    set name = y_min
    set type = no_flux
  end
  subsection boundary 3
    set id   = 3
    set name = y_max
    set type = no_flux
  end
end