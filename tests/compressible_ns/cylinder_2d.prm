#
# Test parameter file for the compressible solver
#

subsection Dimension
  set dimension = 2
end

subsection Timer
  set enable timer = true
end

subsection Output
  set write vtu results    = true
  set output directory = ../tmp/results/cylinder_2d/
  set output prefix    = solution
end

subsection Mesh
  set mesh file = /home/monet/p120488/code/fez/tmp/cylinder.msh
end

subsection Time integration
  set verbosity = verbose
  set dt        = 0.01
  set t_initial = 0
  set t_end     = 0.5
  set scheme    = stationary
  set bdf start method = initial condition
end

subsection Nonlinear solver
  set verbosity            = verbose
  set tolerance            = 1e-10
  set divergence_tolerance = 1e+8
  set max_iterations       = 50
  set enable_line_search   = true
  set analytic_jacobian    = true
end

subsection Linear solver
  subsection main physics
    set verbosity      = quiet
    set method         = direct_mumps
    set reuse          = true
  end
end

subsection FiniteElements
  set Velocity degree            = 2
  set Pressure degree            = 1
  set Temperature degree         = 2
end

subsection Physical properties
  set number of fluids = 1
  subsection Fluid 0
    set thermal conductivity = 0.0256
    set heat capacity at constant pressure = 1006.1
    set dynamic viscosity = 0.0001 #1.82e-5
    set density = 1.2049446433030884
    set pressure reference= 101325
    set temperature reference = 293
  end
end

subsection Initial conditions
  subsection velocity
    set Function expression = 0 ; 0
  end
  subsection pressure
    set Function expression = 0
  end
  subsection temperature
    set Function expression = 0
  end
end

subsection Fluid boundary conditions
  set number = 5
  set fix pressure constant = false
  set enforce zero mean pressure = false
  subsection boundary 0
    set id   = 1
    set name = BottomSymmetry
    set type = slip
  end
  subsection boundary 1
    set id   = 2
    set name = Outlet
    set type = outflow
    #set impose pressure = true
    #set impose velocity = false
    set constrain tangential velocity = true
    #set pressure treatment = weak_traction
    #subsection p
    #  set Function expression = 0
    #end
  end
  subsection boundary 2
    set id   = 3
    set name = TopSymmetry
    set type = slip
  end
  subsection boundary 3
    set id   = 4
    set name = Inlet
    set type = input_function
    set impose pressure = false
    set impose velocity = true
    subsection u
      set Function expression = 3e-4
    end
    subsection v
      set Function expression = 0
    end
  end
  subsection boundary 4
    set id   = 5
    set name = CylinderWall
    set type = no_slip
  end
end

subsection Heat boundary conditions
  set number = 5
  subsection boundary 0
    set id   = 1
    set name = BottomSymmetry
    set type = adiabatic
  end
  subsection boundary 1
    set id   = 2
    set name = Outlet
    set type = adiabatic
  end
  subsection boundary 2
    set id   = 3
    set name = TopSymmetry
    set type = adiabatic
  end
  subsection boundary 3
    set id   = 4
    set name = Inlet
    set type = input_function
    subsection temperature
      set Function expression = 0
    end
  end
  subsection boundary 4
    set id   = 5
    set name = CylinderWall
    set type = adiabatic
  end
end