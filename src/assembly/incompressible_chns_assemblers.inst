
namespace Assembly
{
  namespace IncompressibleCHNS
  {
    /**
     * Main volume assembler
     */
    template class VolumeAssembler<2,
                                   NavierStokesScratch::ScratchDataCHNS<2>,
                                   CopyDataBase<>>;
    template class VolumeAssembler<3,
                                   NavierStokesScratch::ScratchDataCHNS<3>,
                                   CopyDataBase<>>;
    template class VolumeAssembler<2,
                                   NavierStokesScratch::ScratchDataCHNS<2, true>,
                                   CopyDataBase<>>;
    template class VolumeAssembler<3,
                                   NavierStokesScratch::ScratchDataCHNS<3, true>,
                                   CopyDataBase<>>;

    template class VolumeAssembler<2,
                                   NavierStokesScratch::ScratchDataCHNS<2>,
                                   CopyDataBase<>,
                                   stabilization>;
    template class VolumeAssembler<3,
                                   NavierStokesScratch::ScratchDataCHNS<3>,
                                   CopyDataBase<>,
                                   stabilization>;
    template class VolumeAssembler<2,
                                   NavierStokesScratch::ScratchDataCHNS<2, true>,
                                   CopyDataBase<>,
                                   stabilization>;
    template class VolumeAssembler<3,
                                   NavierStokesScratch::ScratchDataCHNS<3, true>,
                                   CopyDataBase<>,
                                   stabilization>;

    template class VolumeAssembler<2,
                                   NavierStokesScratch::ScratchDataCHNS<2>,
                                   CopyDataBase<>,
                                   tracer_stabilization>;
    template class VolumeAssembler<3,
                                   NavierStokesScratch::ScratchDataCHNS<3>,
                                   CopyDataBase<>,
                                   tracer_stabilization>;
    template class VolumeAssembler<2,
                                   NavierStokesScratch::ScratchDataCHNS<2, true>,
                                   CopyDataBase<>,
                                   tracer_stabilization>;
    template class VolumeAssembler<3,
                                   NavierStokesScratch::ScratchDataCHNS<3, true>,
                                   CopyDataBase<>,
                                   tracer_stabilization>;

    template class VolumeAssembler<2,
                                   NavierStokesScratch::ScratchDataCHNS<2>,
                                   CopyDataBase<>,
                                   stabilization | tracer_stabilization>;
    template class VolumeAssembler<3,
                                   NavierStokesScratch::ScratchDataCHNS<3>,
                                   CopyDataBase<>,
                                   stabilization | tracer_stabilization>;
    template class VolumeAssembler<2,
                                   NavierStokesScratch::ScratchDataCHNS<2, true>,
                                   CopyDataBase<>,
                                   stabilization | tracer_stabilization>;
    template class VolumeAssembler<3,
                                   NavierStokesScratch::ScratchDataCHNS<3, true>,
                                   CopyDataBase<>,
                                   stabilization | tracer_stabilization>;

    // With moving mesh
    template class VolumeAssembler<2,
