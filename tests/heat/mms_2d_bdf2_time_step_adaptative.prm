subsection Dimension
  set dimension = 2
end

subsection Timer
  set enable timer = false
end

subsection Output
  set write vtu results = false
  set output directory  = ./heat_out/
  set output prefix     = solution
end

subsection Time integration
  set scheme           = BDF2
  set bdf start method = initial condition

  set t_initial = 0
  set t_end     = 0.5  
  set dt     = 0.01

  set adaptative_dt = true
  set dt min factor = 0.0001
  set dt max factor = 1000
  set reject factor = 5
  set ignoring step = 20
  set max reject step = 3
  set safety = 0.9

  set eps_t   = 2e-3

  set mms_scale_eps_with_dt = true
  set verbosity = verbose
end

subsection Nonlinear solver
  set tolerance            = 1e-12
  set divergence_tolerance = 1e+4
  set max_iterations       = 20
  set enable_line_search   = true
  set analytic_jacobian    = true

  subsection reassembly heuristic
    set decrease tolerance = 0.02
  end

  set verbosity = verbose
end

subsection Linear solver
  subsection main physics 
    set verbosity      = quiet
    set method         = direct_mumps
    set reuse          = true
   end
end

subsection FiniteElements
  set Temperature degree = 2
end

subsection Initial conditions
  set to mms = true
end

subsection Heat boundary conditions
  set number = 4

  subsection boundary 0
    set id   = 1
    set name = x_min
    set type = dirichlet_mms
  end

  subsection boundary 1
    set id   = 2
    set name = x_max
    set type = dirichlet_mms
  end

  subsection boundary 2
    set id   = 3
    set name = y_min
    set type = dirichlet_mms
  end

  subsection boundary 3
    set id   = 4
    set name = y_max
    set type = dirichlet_mms
  end
end


subsection Exact solution
  subsection exact temperature
    set Function expression = sin(20*t)
  end
end

subsection Manufactured solution
  set enable            = true
  set type              = time
  set convergence steps = 4

  subsection Space convergence
    set use dealii cube mesh = true
    set norms to compute     = L2_norm, Linfty_norm
  end

  subsection Time convergence
    set norm = Linfty
  end
end

subsection Debug
  set compare jacobian matrix with fd = false
end
